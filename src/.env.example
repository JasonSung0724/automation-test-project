# Environment
BASE_URL=https://dev.mrsplitter.com
API_BASE_URL=https://dev.mrsplitter.com/api

# Auth Token (optional, leave empty for demo-token API)
AUTH_TOKEN=

# Test Key for creating/deleting test users
TEST_KEY=

# Browser
HEADLESS=true
SLOW_MO=0
BROWSER=chromium

# Old User (fixed, persists across runs)
OLD_USER_TOKEN=
OLD_USER_ID=
OLD_USER_DISPLAY_NAME=Old E2E Bot
